#!/bin/bash
set -euo pipefail

usage() {
    echo "Usage: $0 [--name NAME] [repo...] [-- command...]"
    echo ""
    echo "  repo    GitHub repo (owner/repo) or full git URL (zero or more)"
    echo "  --name  Sandbox name (default: auto-generated by openshell)"
    echo "  --      Separator; everything after is the command to run in the sandbox"
    echo ""
    echo "Examples:"
    echo "  $0                         # no repos, run claude"
    echo "  $0 owner/repo              # clone repo, run claude"
    echo "  $0 a/one b/two             # clone both, run claude"
    echo "  $0 a/one -- zsh            # clone repo, run zsh"
    echo "  $0 -- zsh                  # no repos, run zsh"
    echo "  $0 --name my-box a/one     # clone repo, named sandbox"
    echo ""
    echo "Prerequisites:"
    echo "  .env file in current directory with GH_TOKEN and CLAUDE_CODE_OAUTH_TOKEN"
    exit 1
}

NAME=""
REPOS=()
CMD_ARGS=()
SEEN_DASHDASH=false

while [ $# -gt 0 ]; do
    if $SEEN_DASHDASH; then
        CMD_ARGS+=("$1")
        shift
    elif [ "$1" = "--" ]; then
        SEEN_DASHDASH=true
        shift
    elif [ "$1" = "--name" ]; then
        shift
        NAME="${1:-}"
        [ -z "$NAME" ] && usage
        shift
    elif [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        usage
    else
        REPOS+=("$1")
        shift
    fi
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

ENV_FILE=".env"
if [ ! -f "$ENV_FILE" ]; then
    echo "Error: .env file not found in current directory"
    exit 1
fi

# TODO: currently not using provider, using .env file instead. The OAUTH token
# isn't working with how openshell handles credentials (it isn't injecting the
# actual token).

# Ensure claude-oauth provider exists (created once, reused across sandboxes)

# if ! openshell provider get claude-oauth &>/dev/null; then
#     if [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
#         echo "Error: Provider 'claude-oauth' not found and CLAUDE_CODE_OAUTH_TOKEN is not set."
#         exit 1
#     fi
#     echo "Creating claude-oauth provider..."
#     openshell provider create --name claude-oauth --type generic \
#         --credential CLAUDE_CODE_OAUTH_TOKEN
# fi

# Ensure github provider exists (created once, reused across sandboxes)

# if ! openshell provider get github &>/dev/null; then
#     echo "Creating github provider..."
#     openshell provider create --name github --type github --from-existing
# fi

# Build entrypoint arguments: repos... [-- command...]
ENTRYPOINT_ARGS=("${REPOS[@]+"${REPOS[@]}"}")
if [ ${#CMD_ARGS[@]} -gt 0 ]; then
    ENTRYPOINT_ARGS+=("--" "${CMD_ARGS[@]}")
fi

# Build openshell sandbox create command
OPENSHELL_ARGS=(
    sandbox create
    --from "$SCRIPT_DIR"
    --policy "$SCRIPT_DIR/policy.yaml"
    --provider claude-oauth
    --provider github
    --upload "$ENV_FILE"
)
if [ -n "$NAME" ]; then
    OPENSHELL_ARGS+=(--name "$NAME")
fi
OPENSHELL_ARGS+=(-- /opt/claude-gsd/entrypoint.sh ${ENTRYPOINT_ARGS[@]+"${ENTRYPOINT_ARGS[@]}"})

echo "Creating sandbox${NAME:+ '$NAME'} with ${#REPOS[@]} repo(s)..."
openshell "${OPENSHELL_ARGS[@]}"
