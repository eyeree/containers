#!/bin/bash
set -e

if [ -z "$1" ]; then
    echo "Usage: $0 <container-name>" >&2
    exit 1
fi

NAME="$1"

read -p "Delete container '$NAME' and its volumes? [y/N] " confirm
if [[ "$confirm" != [yY] ]]; then
    echo "Aborted." >&2
    exit 1
fi

docker compose -p "$NAME" down --volumes
docker rmi "${NAME}-sandbox" 2>/dev/null || true
