#!/bin/bash
set -euo pipefail

usage() {
    echo "Usage: $0 [--name NAME] [--build] [--env FILE] [repo...] [-- command...]"
    echo ""
    echo "  repo     GitHub repo (owner/repo) or full git URL (zero or more)"
    echo "  --name   Sandbox name (default: auto-generated by openshell)"
    echo "  --build  Force image rebuild (default: use pre-built image from ./build)"
    echo "  --env    Path to .env file (default: .env in current directory)"
    echo "  --       Separator; everything after is the command to run in the sandbox"
    echo ""
    echo "Examples:"
    echo "  $0                         # no repos, run claude"
    echo "  $0 owner/repo              # clone repo, run claude"
    echo "  $0 a/one b/two             # clone both, run claude"
    echo "  $0 a/one -- zsh            # clone repo, run zsh"
    echo "  $0 -- zsh                  # no repos, run zsh"
    echo "  $0 --name my-box a/one     # clone repo, named sandbox"
    echo "  $0 --build owner/repo      # rebuild image, then create sandbox"
    echo ""
    echo "Prerequisites:"
    echo "  .env file in current directory with GH_TOKEN and CLAUDE_CODE_OAUTH_TOKEN"
    echo "  Run ./build first to push the image to the gateway (only needed once)"
    exit 1
}

NAME=""
FORCE_BUILD=false
ENV_FILE=".env"
REPOS=()
CMD_ARGS=()
SEEN_DASHDASH=false

while [ $# -gt 0 ]; do
    if $SEEN_DASHDASH; then
        CMD_ARGS+=("$1")
        shift
    elif [ "$1" = "--" ]; then
        SEEN_DASHDASH=true
        shift
    elif [ "$1" = "--name" ]; then
        shift
        NAME="${1:-}"
        [ -z "$NAME" ] && usage
        shift
    elif [ "$1" = "--build" ]; then
        FORCE_BUILD=true
        shift
    elif [ "$1" = "--env" ]; then
        shift
        ENV_FILE="${1:-}"
        [ -z "$ENV_FILE" ] && usage
        shift
    elif [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        usage
    else
        REPOS+=("$1")
        shift
    fi
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -f "$ENV_FILE" ]; then
    echo "Error: env file not found: $ENV_FILE"
    exit 1
fi

# TODO: currently not using provider, using .env file instead. The OAUTH token
# isn't working with how openshell handles credentials (it isn't injecting the
# actual token).

    # --provider claude-oauth
    # --provider github

# Ensure claude-oauth provider exists (created once, reused across sandboxes)

