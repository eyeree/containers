#     if [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
#         echo "Error: Provider 'claude-oauth' not found and CLAUDE_CODE_OAUTH_TOKEN is not set."
#         exit 1
#     fi
#     echo "Creating claude-oauth provider..."
#     openshell provider create --name claude-oauth --type generic \
#         --credential CLAUDE_CODE_OAUTH_TOKEN
# fi

# Ensure github provider exists (created once, reused across sandboxes)

# if ! openshell provider get github &>/dev/null; then
#     echo "Creating github provider..."
#     openshell provider create --name github --type github --from-existing
# fi

# Build entrypoint arguments: repos... [-- command...]
ENTRYPOINT_ARGS=("${REPOS[@]+"${REPOS[@]}"}")
if [ ${#CMD_ARGS[@]} -gt 0 ]; then
    ENTRYPOINT_ARGS+=("--" "${CMD_ARGS[@]}")
fi

# Determine image source
TAG_FILE="$SCRIPT_DIR/.image-tag"

if $FORCE_BUILD; then
    echo "Building image..."
    "$SCRIPT_DIR/build"
fi

if [ -f "$TAG_FILE" ]; then
    IMAGE_FROM="$(cat "$TAG_FILE")"
    echo "Using pre-built image: $IMAGE_FROM"
else
    echo "No pre-built image found. Run ./build first, or use --build to build inline."
    echo ""
    echo "  ./build           # build once, then use ./create (fast)"
    echo "  ./create --build  # build inline (slow, pushes ~1 GiB each time)"
    exit 1
fi

# Build openshell sandbox create command
OPENSHELL_ARGS=(
    sandbox create
    --from "$IMAGE_FROM"
    --policy "$SCRIPT_DIR/policy.yaml"
    --upload "$ENV_FILE:.tmpenv"
)
if [ -n "$NAME" ]; then
    OPENSHELL_ARGS+=(--name "$NAME")
fi
OPENSHELL_ARGS+=(-- /opt/claude-gsd/entrypoint.sh ${ENTRYPOINT_ARGS[@]+"${ENTRYPOINT_ARGS[@]}"})

echo "Creating sandbox${NAME:+ '$NAME'} with ${#REPOS[@]} repo(s)..."
echo openshell "${OPENSHELL_ARGS[@]}"
openshell "${OPENSHELL_ARGS[@]}"
